# /etc/default/cmon-proxy.env
# Environment variables for cmon-proxy (loaded by systemd)
# Uncomment and modify as needed.

# Usage metering (disabled by default)
#METERING_ENABLED=true
#METERING_DB_PATH=/var/lib/ccmgr/metering.db
#METERING_INTERVAL=60m
#METERING_SIGNING_KEY=your-secret-signing-key
#METERING_KEY_ID=key-2026-01

# OpenTelemetry metering emitter (v2 — emits to cmon-billing service)
#OTEL_METERING_ENABLED=true
#OTEL_METERING_ENDPOINT=localhost:4317
#OTEL_METERING_INTERVAL=60m
#OTEL_METERING_INSECURE=true
#OTEL_METERING_INSTANCE=cmon-proxy-01
